{
    // Unique numeric ID for this node — must not conflict with any other server
    "server_id": 2,

    // Must match the name declared in network.conf peers list
    "server_name": "services.example.com",

    "management": {
        "address": "0.0.0.0:8888",
        "client_ca": "/sable/certs/ca_cert.pem",
        // Add operator fingerprints here for management API access
        "authorised_fingerprints": [],
    },

    "server": {
        // Path where the services database will be stored
        "database": "/sable/data/services.json",

        // Default roles assigned to newly registered channels.
        // builtin:founder, builtin:op, and builtin:voice are required.
        "default_roles": {
            "builtin:founder": [
                "founder", "access_view", "access_edit", "role_view", "role_edit",
                "op_self", "op_grant",
                "voice_self", "voice_grant",
                "always_send",
                "invite_self", "invite_other",
                "receive_op", "receive_voice", "receive_opmod",
                "topic", "kick", "set_simple_mode", "set_key",
                "rename",
                "ban_view", "ban_add", "ban_remove_any",
                "quiet_view", "quiet_add", "quiet_remove_any",
                "exempt_view", "exempt_add", "exempt_remove_any",
                "invex_view", "invex_add", "invex_remove_any"
            ],
            "builtin:op": [
                "always_send",
                "receive_op", "receive_voice", "receive_opmod",
                "topic", "kick", "set_simple_mode", "set_key",
                "rename",
                "ban_view", "ban_add", "ban_remove_any",
                "quiet_view", "quiet_add", "quiet_remove_any",
                "exempt_view", "exempt_add", "exempt_remove_any",
                "invex_view", "invex_add", "invex_remove_any"
            ],
            "builtin:voice": [
                "always_send", "voice_self", "receive_voice"
            ],
        },

        "password_hash": {
            // Only "bcrypt" is supported
            "algorithm": "bcrypt",
            // Work factor (4–31). 12 is a reasonable production value.
            "cost": 12,
            "version": "2b",
        },
    },

    "event_log": {
        "event_expiry": 86400, // 24 hours
    },

    "tls_config": {
        "key_file": "/sable/certs/services.key",
        "cert_file": "/sable/certs/services.pem",
    },

    "node_config": {
        // Listen on all interfaces inside the container
        "listen_addr": "0.0.0.0:6668",
        "cert_file": "/sable/certs/services.pem",
        "key_file": "/sable/certs/services.key",
    },

    "log": {
        "dir": "/sable/data/logs/",
        "stdout": "stdout.log",
        "stderr": "stderr.log",
        "pidfile": "sable.pid",

        "module-levels": {
            "rustls": "warn",
            "tracing": "warn",
            "sable": "debug",
            "": "info",
        },

        "targets": [
            {
                "target": "stdout",
                "level": "info",
            },
            {
                "target": { "filename": "sable.log" },
                "level": "info",
            },
        ],
    },
}
