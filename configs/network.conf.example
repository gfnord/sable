{
    // Number of peers each node forwards each event to.
    // Tune based on network size vs. bandwidth trade-off.
    "fanout": 2,

    // CA certificate used to validate all node TLS certificates.
    // Must be the same on every node.
    "ca_file": "/sable/certs/ca_cert.pem",

    // All server nodes in the network, including ircd and services nodes.
    // Every node must appear here with its gossip address and certificate fingerprint.
    // Get the fingerprint with: openssl x509 -in <cert.pem> -fingerprint -sha1 -noout
    "peers": [
        {
            "name": "irc.example.com",
            "address": "sable-ircd-1:6668",
            "fingerprint": "replace-with-sha1-fingerprint-of-ircd-cert"
        },
        {
            "name": "services.example.com",
            "address": "sable-services:6668",
            "fingerprint": "replace-with-sha1-fingerprint-of-services-cert"
        },
    ]
}
